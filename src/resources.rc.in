#include <winver.h>

1 ICON "@CMAKE_CURRENT_SOURCE_DIR@/src/Stack.ico"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION @STACK_VERSION_MAJOR@,@STACK_VERSION_MINOR@,@STACK_VERSION_PATCH@,0
 PRODUCTVERSION @STACK_VERSION_MAJOR@,@STACK_VERSION_MINOR@,@STACK_VERSION_PATCH@,0
 FILEFLAGSMASK VS_FFI_FILEFLAGSMASK
#ifdef _DEBUG
 FILEFLAGS VS_FF_DEBUG
#else
 FILEFLAGS 0x0L
#endif
 FILEOS VOS__WINDOWS32
 FILETYPE VFT_APP
 FILESUBTYPE VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "@STACK_PUBLISHER@\0"
            VALUE "FileDescription", "Stack\0"
            VALUE "FileVersion", "@STACK_VERSION@\0"
            VALUE "InternalName", "Stack\0"
            VALUE "OriginalFilename", "Stack.exe\0"
            VALUE "ProductName", "Stack\0"
            VALUE "ProductVersion", "@STACK_VERSION@\0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END
